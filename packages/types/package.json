{
  "name": "@vantare/types",
  "version": "0.1.0",
  "private": true,
  "description": "Vantare public TypeScript types",
  "main": "./dist/index.js",
  "module": "./dist/packages/types/src/index.js",
  "types": "./dist/packages/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/types/src/index.d.ts",
      "import": "./dist/packages/types/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@vantare/auth": "workspace:*",
    "@vantare/sim-core": "workspace:*"
  },
  "type": "module"
}